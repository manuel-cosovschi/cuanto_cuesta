# URL pública del sitio (sin barra final). Se usa para canonicals, OG, sitemap, JSON-LD.
NEXT_PUBLIC_SITE_URL=https://cuantocuestaargentina.com

# ID de cliente de Google AdSense (publisher ID). Formato esperado: ca-pub-XXXXXXXXXXXXXXXX
# Dejar vacío hasta que el sitio esté aprobado. Mientras tanto NO se renderizan anuncios.
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# Proveedor de analytics: "none" | "ga4" | "plausible"
NEXT_PUBLIC_ANALYTICS_PROVIDER=none

# IDs opcionales según provider
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
